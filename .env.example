DATABASE_URL=postgresql://app_user:change-me@127.0.0.1:5432/friend_nest
BETTER_AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters-long
BETTER_AUTH_URL=http://localhost:3000
# Cloudflare Quick Tunnel 的 *.trycloudflare.com 已由应用自动信任。
TRUSTED_ORIGINS=http://localhost:3000,http://YOUR-LAN-IP:3000
REGISTRATION_GATE_SECRET=replace-with-an-internal-registration-secret
BOOTSTRAP_KEY=replace-with-a-private-founder-setup-key
# 本地媒体维护接口使用；生产环境应由受控定时任务携带该密钥调用。
MEDIA_MAINTENANCE_SECRET=replace-with-a-random-media-maintenance-secret
# 本地默认使用项目根目录下的 .data；单机部署请填写持久化挂载盘的绝对路径。
PRIVATE_DATA_ROOT=/absolute/path/to/along-data
